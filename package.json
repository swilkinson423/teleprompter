{
	"name": "teleprompter",
	"version": "1.0.0",
	"private": true,
	"workspaces": [
		"client",
		"server"
	],
	"description": "Teleprompter app",
	"main": "index.js",
	"scripts": {
		"dev": "npm-run-all -p dev:server dev:client",
		"dev:server": "npm --workspace server run dev",
		"dev:client": "npm --workspace client run dev",
		"build": "npm --workspace client run build",
		"start": "npm --workspace server run start"
	},
	"devDependencies": {
		"npm-run-all": "^4.1.5"
	}
}